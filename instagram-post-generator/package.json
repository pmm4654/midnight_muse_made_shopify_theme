{
  "name": "instagram-post-generator",
  "version": "1.0.0",
  "description": "AI-powered Instagram post generator for Midnight Muse Made — picks products, writes captions, and suggests visuals",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "generate": "node scripts/generate-post.js",
    "publish": "node scripts/publish-post.js",
    "init-session": "node scripts/publish-post.js --init-session",
    "check-session": "node scripts/publish-post.js --check-session"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "node-fetch": "^2.7.0",
    "playwright": "^1.58.2"
  }
}
