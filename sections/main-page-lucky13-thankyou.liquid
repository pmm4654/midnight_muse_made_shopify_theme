{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .lucky13-thankyou {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .lucky13-thankyou {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lucky13-thankyou__title {
    font-size: calc(var(--font-heading-scale) * 3rem);
    margin-bottom: 0.3rem;
    line-height: 1.1;
  }

  @media screen and (min-width: 750px) {
    .lucky13-thankyou__title {
      font-size: calc(var(--font-heading-scale) * 4rem);
    }
  }

  .lucky13-thankyou__subtitle {
    font-size: calc(var(--font-heading-scale) * 1.8rem);
    color: rgba(var(--color-button), 1);
    margin-bottom: 1.5rem;
  }

  .lucky13-thankyou__body {
    max-width: 600px;
    margin: 0 auto 2rem;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .lucky13-thankyou__email-hint {
    display: inline-block;
    background: rgba(var(--color-button), 0.1);
    border: 1px solid rgba(var(--color-button), 0.3);
    border-radius: 4px;
    padding: 0.5rem 1.2rem;
    margin: 1rem 0;
    font-style: italic;
  }

  .lucky13-thankyou__divider {
    width: 60px;
    height: 2px;
    background: rgba(var(--color-button), 0.4);
    margin: 2rem auto;
    border: none;
  }

  .lucky13-thankyou__share {
    margin-top: 2rem;
  }

  .lucky13-thankyou__share-heading {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .lucky13-thankyou__social-links {
    display: flex;
    justify-content: center;
    gap: 1.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .lucky13-thankyou__social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: 4px;
    color: rgba(var(--color-foreground), 1);
    text-decoration: none;
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s;
  }

  .lucky13-thankyou__social-link:hover {
    border-color: rgba(var(--color-button), 0.6);
    color: rgba(var(--color-button), 1);
  }

  .lucky13-thankyou__social-link svg {
    width: 20px;
    height: 20px;
  }

  .lucky13-thankyou__browse {
    margin-top: 2.5rem;
  }

  .lucky13-thankyou__browse-cta {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 1rem;
    opacity: 0.8;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width lucky13-thankyou">
    <div class="lucky13-thankyou__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      <h1 class="lucky13-thankyou__title">{{ section.settings.heading }}</h1>
      <h2 class="lucky13-thankyou__subtitle">{{ section.settings.subtitle }}</h2>
    </div>

    <div class="lucky13-thankyou__body{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.body_text }}

      {%- if section.settings.email_subject_hint != blank -%}
        <div class="lucky13-thankyou__email-hint">
          Look for: <strong>{{ section.settings.email_subject_hint }}</strong>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Render any RTE content from Shopify Admin {%- endcomment -%}
    {%- if page.content != blank -%}
      <div class="rte page-content">
        {{ page.content }}
      </div>
    {%- endif -%}

    <hr class="lucky13-thankyou__divider">

    {%- if section.settings.show_share_links -%}
      <div class="lucky13-thankyou__share{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <p class="lucky13-thankyou__share-heading">{{ section.settings.share_heading }}</p>
        <ul class="lucky13-thankyou__social-links">
          {%- if settings.social_instagram_link != blank -%}
            <li>
              <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" class="lucky13-thankyou__social-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                Instagram
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <li>
              <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" class="lucky13-thankyou__social-link">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 3 15.57 6.33 6.33 0 0 0 9.37 22a6.33 6.33 0 0 0 6.37-6.23V9.34a8.16 8.16 0 0 0 3.85.97V6.69z"/></svg>
                TikTok
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <li>
              <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" class="lucky13-thankyou__social-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                Facebook
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if section.settings.show_browse_cta -%}
      <div class="lucky13-thankyou__browse{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <p class="lucky13-thankyou__browse-cta">{{ section.settings.browse_text }}</p>
        <a href="{{ section.settings.browse_link }}" class="button button--primary">
          {{ section.settings.browse_button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Lucky 13 Thank You",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-purple-accent"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Circle is Nearly Complete"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "You've claimed your place."
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>You've claimed your place among the Lucky 13. Your <strong>50% discount code</strong> is flying to your inbox right now — conjured just for you.</p><p>While you wait, feast your eyes on what your enchantment could conjure...</p>"
    },
    {
      "type": "text",
      "id": "email_subject_hint",
      "label": "Email subject line hint",
      "default": "Your 50% Spell Has Been Cast",
      "info": "Helps subscribers find the email in their inbox"
    },
    {
      "type": "header",
      "content": "Social sharing"
    },
    {
      "type": "checkbox",
      "id": "show_share_links",
      "label": "Show social follow links",
      "default": true
    },
    {
      "type": "text",
      "id": "share_heading",
      "label": "Share heading",
      "default": "Know another creature of the night? Tell them before the spots vanish."
    },
    {
      "type": "header",
      "content": "Browse CTA"
    },
    {
      "type": "checkbox",
      "id": "show_browse_cta",
      "label": "Show browse button",
      "default": true
    },
    {
      "type": "text",
      "id": "browse_text",
      "label": "Browse prompt text",
      "default": "See what your 50% off could conjure:"
    },
    {
      "type": "text",
      "id": "browse_button_label",
      "label": "Browse button label",
      "default": "Browse the Collection"
    },
    {
      "type": "url",
      "id": "browse_link",
      "label": "Browse button link"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ]
}
{% endschema %}
